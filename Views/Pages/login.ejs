<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>EJS Is Fun</title>
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="/login-register.css">
</head>
<body>

<header>
</header>

<main>
  <section class="container" id="container">

    <!-- Inloggen -->
    <section class="sectie" aria-labelledby="titel-inloggen">
      <form class="formulier-box-login">
        <h2 id="titel-inloggen">Inloggen</h2>

        <label for="inlog-gebruikersnaam">Gebruikersnaam</label>
        <input id="inlog-gebruikersnaam" type="text" name="username" required>

        <label for="inlog-wachtwoord">Wachtwoord</label>
        <input id="inlog-wachtwoord" type="password" name="password" required>

        <button type="submit">Inloggen</button>

        <button type="button" class="link" onclick="gaNaar(1)">
          Nog geen account? <u><strong>Registreer</strong></u>
        </button>
      </form>
    </section>

    <!-- Registratie Stap 1 -->
    <section class="sectie" aria-labelledby="titel-registratie-stap1">
      <form class="formulier-box" id="formulier-registratie">

      <fieldset class="stap" id="stap1" style="display:none;">
        <h2 id="titel-registratie-stap1">Registreren - Stap 1</h2>

        <label for="reg-gebruikersnaam">Gebruikersnaam</label>
        <input id="reg-gebruikersnaam" type="text" name="username" required>

        <label for="reg-email">Email</label>
        <input id="reg-email" type="email" name="email" required>

        <label for="reg-wachtwoord">Wachtwoord</label>
        <input id="reg-wachtwoord" type="password" name="password" required>

        <div>
          <button type="button" class="knop-primaire" onclick="gaNaar(2)">Volgende</button>
          <button type="button" class="link" onclick="gaTerugNaar(0)">
            Heb je al een account <u><strong>log hier in</strong></u>      
          </button>
        </div>
      </fieldset>

      <!-- Stap 2 -->
      <fieldset class="stap" id="stap2" style="display:none;">
        <h2 id="titel-registratie-stap2">Registreren - Stap 2</h2>

        <label for="reg-geboortedatum">Geboortedatum</label>
        <input id="reg-geboortedatum" type="date" name="dob" required>

        <label for="reg-geslacht">Geslacht</label>
        <select id="reg-geslacht" name="gender">
          <option value="man">Man</option>
          <option value="vrouw">Vrouw</option>
        </select>

        <div>
          <div class="knoppen-rij">
            <button type="button" class="knop-secundaire" onclick="gaNaar(1)">Terug</button>
            <button type="button" class="knop-primaire" onclick="gaNaar(3)">Volgende</button>
          </div>
          <button type="button" class="link" onclick="gaTerugNaar(0)">
            Heb je al een account <u><strong>log hier in</strong></u>       
          </button>
        </div>
      </fieldset>

      <!-- Stap 3 -->
      <fieldset class="stap" id="stap3" style="display:none;">
        <h2 id="titel-registratie-stap3">Registreren - Stap 3</h2>

        <label for="reg-wachtwoord2">Wachtwoord</label>
        <input id="reg-wachtwoord2" type="password" name="reg-password2" required>

        <label for="reg-wachtwoord-bevestigen">Bevestig wachtwoord</label>
        <input id="reg-wachtwoord-bevestigen" type="password" name="confirm_password" required>

        <div>
          <div class="knoppen-rij">
            <button type="button" class="knop-secundaire" onclick="gaNaar(2)">Terug</button>
            <button type="submit" class="knop-primaire">Registreren</button>
          </div>
          <button type="button" class="link" onclick="gaTerugNaar(0)">
            Heb je al een account <u><strong>log hier in</strong></u>       
          </button>
        </div>
      </fieldset>
    </form>
    </section>

  </section>
</main>

<script src="/js/login-register.js"></script>

<footer>
</footer>

</body>
</html>